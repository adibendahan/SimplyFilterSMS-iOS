//MARK: Help View
"faq_subtitle" = "Hier sind häufig gestellte Fragen. Falls du keine Antwort findest, kontaktiere uns per";

"faq_question_0" = "Wie aktiviere ich die Nachrichtenfilterung in iOS?";

"faq_answer_0" = "Tippe hier, um zum Einrichtungsbildschirm zu gelangen.";

"faq_question_1" = "Wie funktioniert die Nachrichtenfilterung?";

"faq_answer_1" = "Wenn du eine SMS von einer Nummer erhältst, die nicht in deinen Kontakten ist, filtert Simply Filter SMS sie nach folgenden Regeln:\n\n• Enthält die Nachricht Text aus der 'Erlaubte Texte'-Liste, wird sie normal zugestellt.\n• Andernfalls wird sie nach 'Blockierte Texte' durchsucht. Wird ein Treffer gefunden, kommt sie in den Junk-Ordner.\n• Ohne Treffer wird die Nachricht normal zugestellt.\n";

"faq_question_2" = "Sind meine Nachrichten für den App-Entwickler einsehbar?";

"faq_answer_2" = "Nein. Simply Filter SMS sammelt keinerlei Informationen. Die gesamte Nachrichtenverarbeitung erfolgt lokal auf deinem Gerät ohne jegliche Protokollierung.";

"faq_question_3" = "Was ist mit iMessages und Nachrichten von meinen Kontakten?";

"faq_answer_3" = "Apple gibt diese Nachrichten nicht an Entwickler weiter. Sie bleiben vollständig privat.";

"faq_question_4" = "Wo sind die gefilterten Nachrichten?";

"faq_answer_4" = "Wenn eine Nachricht als Junk markiert wird, ist sie weiterhin in der Nachrichten-App im Junk-Ordner lesbar.";

"faq_question_5" = "Was ist der Unterschied zwischen Junk/Transaktionen/Werbung-Ordnern?";

"faq_answer_5" = "Kaum etwas. Du kannst jedes Wort in jeden Ordner filtern. Die Ordner sind nicht anpassbar. Nur Nachrichten im Junk-Ordner werden lautlos zugestellt.";

"help_automaticFiltering_question" = "Wie funktioniert KI-Filterung?";

"help_automaticFiltering" = "KI-Filterung nutzt KI-generierte Schlüsselwortlisten, um Spam zu erkennen und Nachrichten in den Junk-Ordner zu leiten. Die Listen werden regelmäßig aktualisiert. Deine eigenen Filter bleiben aktiv, wenn KI-Filterung eingeschaltet ist.";

"help_deny" = "Füge Texte hinzu, die eine Nachricht als Spam kennzeichnen. Du kannst auch den Zielordner auswählen.";

"help_allow" = "Füge Texte hinzu, die eine Nachricht als gültig kennzeichnen. Empfohlen: einzigartige Texte wie deinen Namen. Texte auf dieser Liste haben die höchste Priorität.";

