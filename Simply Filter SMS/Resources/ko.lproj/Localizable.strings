"faq_subtitle" = "자주 묻는 질문 목록입니다. 답변을 찾지 못하셨다면 다음을 통해 문의하세요";

"faq_question_0" = "iOS에서 메시지 필터링을 어떻게 활성화하나요?";

"faq_answer_0" = "탭하여 온보딩 화면을 여세요.";

"faq_question_1" = "메시지 필터링은 어떻게 작동하나요?";

"faq_answer_1" = "연락처에 없는 번호에서 문자 메시지를 받으면 Simply Filter SMS가 다음 규칙에 따라 필터링합니다:\n\n• 메시지에 '허용 텍스트'의 필터와 일치하는 텍스트가 포함되어 있으면 정상적으로 전달됩니다.\n• 그렇지 않으면 '차단 텍스트'의 필터와 일치하는지 검사하며, 일치하는 항목이 있으면 스팸 폴더로 전달됩니다.\n• 텍스트가 필터와 일치하지 않으면 정상적으로 전달됩니다.\n";

"faq_question_2" = "내 메시지가 앱 개발자에게 노출되나요?";

"faq_answer_2" = "아니요. Simply Filter SMS는 어떠한 정보도 수집하지 않으며, 모든 메시지 처리는 로깅 없이 기기에서 로컬로 이루어집니다.";

"faq_question_3" = "iMessage와 연락처의 메시지는 어떻게 되나요?";

"faq_answer_3" = "Apple은 해당 메시지를 개발자에게 노출하지 않으며 완전히 비공개로 유지됩니다.";

"faq_question_4" = "필터링된 메시지는 어디에 있나요?";

"faq_answer_4" = "문자 메시지가 스팸으로 분류되면 메시지 앱의 스팸 폴더에서 읽을 수 있습니다.";

"faq_question_5" = "스팸/거래/프로모션 폴더의 차이점은 무엇인가요?";

"faq_answer_5" = "큰 차이는 없습니다. 어떤 단어든 어떤 폴더로도 필터링할 수 있습니다. 폴더는 어떠한 방식으로도 커스터마이즈할 수 없습니다. 스팸 폴더로 필터링된 메시지만 무음으로 전달됩니다.";

"help_automaticFiltering_question" = "AI 필터링은 어떻게 작동하나요?";

"help_automaticFiltering" = "AI 필터링은 AI가 생성한 키워드 목록을 사용하여 스팸을 감지하고 메시지를 스팸 폴더로 전달합니다. 목록은 주기적으로 업데이트됩니다. AI 필터링이 켜져 있어도 기존 필터는 계속 적용됩니다.";

"help_deny" = "메시지를 스팸으로 표시할 텍스트를 추가하고, 저장할 폴더도 선택할 수 있습니다.";

"help_allow" = "메시지를 정상으로 표시할 텍스트를 추가하세요. 이름과 같은 고유한 식별 텍스트를 추가하는 것이 좋습니다. 이 목록의 텍스트는 메시지 필터링 시 가장 높은 우선순위를 갖습니다.";

