"faq_subtitle" = "הנה רשימה של שאלות שכיחות, אם אתם לא מוצאים את התשובה לשאלתכם צרו קשר בעזרת";

"faq_question_0" = "איך מפעילים את הסינון במערכת ההפעלה?";

"faq_answer_0" = "לחצו כאן כדי לעבור להסבר על הפעלת הסינון.";

"faq_question_1" = "איך עובד הסינון של ההודעות?";

"faq_answer_1" = "כאשר אתם מקבלים הודעת טקסט ממספר שלא נמצא באנשי הקשר שלכם, Simply Filter SMS תסנן את ההודעה בעזרת החוקים הבאים:\n\n• אם ההודעה מכילה מילה מרשימת המילים המאופשרות היא תתקבל כהודעה רגילה.\n• אם לא, ההודעה תיסרק על מנת למצוא מילים מרשימת המילים החסומות ובמקרה שנמצאה מילה חסומה ההודעה תעבור לתיקיית הזבל.\n• אם ההודעה לא מכילה מילים חסומות, היא תתקבל כהודעה רגילה.\n";

"faq_question_2" = "האם ההודעות שלי חשופות למפתח האפליקציה?";

"faq_answer_2" = "לא. Simply Filter SMS לא אוספת שום מידע על המשתמש, סריקת ההודעות נעשית באופן לוקאלי בלבד על המכשיר מבלי לכתוב כל לוג.";

"faq_question_3" = "מה לגבי iMessages והודעות מאנשי הקשר שלי?";

"faq_answer_3" = "אפל לא חושפת את תוכן ההודעות האלה למפתחים, הן נשארות פרטיות לחלוטין.";

"faq_question_4" = "איפה ההודעות שנחסמו?";

"faq_answer_4" = "כאשר הודעה מסומנת כזבל ניתן עדיין לקרוא אותה בתיקיית הזבל באפליקציית ההודעות במערכת ההפעלה.";

"faq_question_5" = "מה ההבדל בין תיקיית זבל/פעולות/פרסומי?";

"faq_answer_5" = "אין הבדל רב, ניתן לסנן כל מילה לכל תיקייה. התיקיות הינן קבועות ואינן ניתנות לשינוי. רק הודעות שמסוננות לתיקיית זבל יתקבלו ללא כל התראה.";

